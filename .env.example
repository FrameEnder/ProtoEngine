# Copy this file to .env and fill in real secrets before deploying.
# Generate strong values with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

PORT=3000
NODE_ENV=production

# The brand name shown across the UI (page title, header, hero, sign-in
# dialog). Defaults to "Lumen" if unset. Max 40 characters.
APP_NAME=Lumen

# Docker only (e.g. UGREEN NAS): the user/group the container runs as, so it
# can write to the mounted data folders. Set these to your NAS user's uid/gid
# (run `id` over SSH). Defaults to 1000 if unset. Ignored under Podman.
PUID=1000
PGID=1000

# Cookie security. Leave this OFF (or unset) when accessing over plain
# http:// — for example http://127.0.0.1:3000 or http://your-server-ip:3000.
# A Secure cookie is only sent over HTTPS, so turning this on without HTTPS
# makes logins fail to persist (you appear logged out on every refresh).
# Set to true ONLY once you serve over HTTPS, usually via a reverse proxy.
SECURE_COOKIES=false

# REQUIRED in production. Long random strings, kept secret.
SESSION_SECRET=replace-with-a-long-random-hex-string
CSRF_SECRET=replace-with-a-different-long-random-hex-string
